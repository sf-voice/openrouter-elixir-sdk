# copy this file to .env and fill in your keys.
# load it before starting the server:
#   set -a; source .env; set +a
#   mix phx.server

# chat + tts go through openrouter. get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-replace-me

# realtime stt is openai-direct (openrouter doesn't route the realtime
# api). get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-replace-me

# optional — override the default port (4000)
# PORT=4000
