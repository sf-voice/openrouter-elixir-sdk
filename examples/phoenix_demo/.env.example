# copy this file to .env and fill in your keys.
# load it before starting the server:
#   set -a; source .env; set +a
#   mix phx.server

# single key — chat, tts, and stt all route through openrouter.
# get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-replace-me

# optional — override the default port (4000)
# PORT=4000
